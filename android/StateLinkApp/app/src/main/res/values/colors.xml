<?xml version="1.0" encoding="utf-8"?>
<!--
    Color definitions for all 3 themes.
    The actual assignment to theme attributes happens in styles.xml.
    These are raw color constants used by drawables and views.

    Light palette  — clean white/gray with blue accents
    Dark palette   — Material dark with light blue accents
    Tech Blue      — deep navy with cyan/neon accents
-->
<resources>
    <!-- ═══ Light Theme Colors ═══ -->
    <color name="light_primary">#1976D2</color>
    <color name="light_on_primary">#FFFFFF</color>
    <color name="light_surface">#FFFFFF</color>
    <color name="light_surface_variant">#F0F4F8</color>
    <color name="light_on_surface">#212121</color>
    <color name="light_on_surface_variant">#607D8B</color>
    <color name="light_background">#F5F7FA</color>

    <!-- ═══ Dark Theme Colors ═══ -->
    <color name="dark_primary">#90CAF9</color>
    <color name="dark_on_primary">#0D2137</color>
    <color name="dark_surface">#1E1E1E</color>
    <color name="dark_surface_variant">#2C2C2C</color>
    <color name="dark_on_surface">#E0E0E0</color>
    <color name="dark_on_surface_variant">#9E9E9E</color>
    <color name="dark_background">#121212</color>

    <!-- ═══ Tech Blue Theme Colors ═══ -->
    <color name="blue_primary">#00E5FF</color>
    <color name="blue_on_primary">#001F2B</color>
    <color name="blue_surface">#112240</color>
    <color name="blue_surface_variant">#1A3356</color>
    <color name="blue_on_surface">#E0F7FA</color>
    <color name="blue_on_surface_variant">#64B5F6</color>
    <color name="blue_background">#0A1628</color>

    <!-- ═══ Status indicator colors ═══ -->
    <color name="dot_green">#4CAF50</color>
    <color name="dot_red">#F44336</color>

    <!-- ═══ Progress bar colors (used in Java) ═══ -->
    <color name="bar_safe">#4CAF50</color>      <!-- 0–49% -->
    <color name="bar_warning">#FF9800</color>   <!-- 50–79% -->
    <color name="bar_danger">#F44336</color>    <!-- 80–100% -->
</resources>
